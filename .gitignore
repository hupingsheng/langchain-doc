# ============================================================
# Python 项目 .gitignore
# ============================================================

# ----------------------
# Python 运行时文件
# ----------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ----------------------
# 虚拟环境
# ----------------------
.venv/
venv/
env/
ENV/

# ----------------------
# 环境变量 / 敏感信息
# ----------------------
.env
.env.local
.env.*.local

# ----------------------
# 日志文件
# ----------------------
*.log
logs/

# ----------------------
# 测试 / 覆盖率
# ----------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ----------------------
# Jupyter Notebook
# ----------------------
.ipynb_checkpoints/
*.ipynb

# ----------------------
# IDE 配置
# ----------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ----------------------
# Claude Code
# ----------------------
.claude/

# ----------------------
# 操作系统文件
# ----------------------
.DS_Store
Thumbs.db
desktop.ini
